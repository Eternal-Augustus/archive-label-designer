{
  "name": "archive-label-designer",
  "version": "0.1.0",
  "description": "Offline desktop app for A4 archive label layout and printing workflows.",
  "author": "NCEPU Archive Workflow",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "dev:renderer": "vite",
    "build": "vite build",
    "start": "electron .",
    "preview": "vite preview",
    "dist:dir": "npm run build && electron-builder --dir",
    "dist:win:dir": "npm run build && electron-builder --win dir",
    "dist:win": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.2.6"
  },
  "build": {
    "appId": "com.codex.archive-label-designer",
    "productName": "Archive Label Designer",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
